def normalize_column_name(col):
    """Normalize column names to lowercase with underscores."""
    if pd.isna(col):
        return "unnamed"
    col = str(col).strip().lower()
    col = re.sub(r'[\n\r]+', ' ', col)
    col = re.sub(r'\s+', '_', col)
    col = re.sub(r'[^\w\s_]', '', col)
    col = re.sub(r'_+', '_', col)
    return col.strip('_')

def safe_numeric_convert(series):
    """Safely convert series to numeric, handling various formats."""
    if not isinstance(series, pd.Series):
        return series
    
    series = series.replace(['', '-', '—', 'N/A', 'n/a', 'nan', 'NaN', None], np.nan)
    series = series.astype(str).str.replace(',', '').str.strip()
    
    return pd.to_numeric(series, errors='coerce')

def safe_date_convert(value):
    """Safely convert value to date."""
    if pd.isna(value) or value in ['', 'nan', 'NaN', None]:
        return None
    try:
        return pd.to_datetime(value).date()
    except:
        return None

def extract_mass_from_string(text):
    """Extract mass value in kg from text like '200kg' or '350000g'."""
    if not text or pd.isna(text):
        return None
    
    text = str(text).lower().strip()
    
    # Try to parse as number first (might be just "350000" in grams)
    try:
        value = float(text.replace('kg', '').replace('g', '').strip())
        # If > 1000, assume it's in grams
        if value > 1000:
            return value / 1000  # Convert to kg
        else:
            return value  # Already in kg
    except:
        pass
    
    # Look for patterns with units
    patterns = [
        r'(\d+\.?\d*)\s*kg',  # 200kg, 350kg
        r'(\d+\.?\d*)\s*g',   # 350000g
    ]
    
    for pattern in patterns:
        match = re.search(pattern, text)
        if match:
            value = float(match.group(1))
            if 'kg' in pattern:
                return value
            else:  # grams
                return value / 1000
    
    return None

def detect_lab_type(file_path):
    """Detect whether file belongs to F1/E2 or Large Mass lab."""
    try:
        xl = pd.ExcelFile(file_path)
        sheets = [s.lower() for s in xl.sheet_names]
        
        # Check for F1/E2 patterns
        if any('f1' in s or 'e2' in s for s in sheets):
            return "F1/E2"
        
        # Check for Large Mass patterns
        if any(('large' in s and 'mass' in s) or ('results' in s and 'sheet' in s) or 'input' in s for s in sheets):
            return "Large Mass"
        
        return "Unknown"
    except Exception as e:
        print(f"⚠️ Error detecting lab type: {e}")
        return "Unknown"

