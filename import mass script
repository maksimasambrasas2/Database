def normalize_column_name(col):
    """Normalize column names to lowercase with underscores."""
    if pd.isna(col):
        return "unnamed"
    col = str(col).strip().lower()
    col = re.sub(r'[\n\r]+', ' ', col)
    col = re.sub(r'\s+', '_', col)
    col = re.sub(r'[^\w\s_]', '', col)
    col = re.sub(r'_+', '_', col)
    return col.strip('_')

def safe_numeric_convert(series):
    """Safely convert series to numeric, handling various formats."""
    if not isinstance(series, pd.Series):
        return series
    
    series = series.replace(['', '-', '—', 'N/A', 'n/a', 'nan', 'NaN', None], np.nan)
    series = series.astype(str).str.replace(',', '').str.strip()
    
    return pd.to_numeric(series, errors='coerce')

def safe_date_convert(value):
    """Safely convert value to date."""
    if pd.isna(value) or value in ['', 'nan', 'NaN', None]:
        return None
    try:
        return pd.to_datetime(value).date()
    except:
        return None

def detect_lab_type(file_path):
    """Detect whether file belongs to F1/E2 or Large Mass lab."""
    try:
        xl = pd.ExcelFile(file_path)
        sheets = [s.lower() for s in xl.sheet_names]
        
        if any('f1' in s or 'e2' in s for s in sheets):
            return "F1/E2"
        
        if any(('large' in s and 'mass' in s) or ('results' in s and 'sheet' in s) for s in sheets):
            return "Large Mass"
        
        return "Unknown"
    except Exception as e:
        print(f"⚠️ Error detecting lab type: {e}")
        return "Unknown"

