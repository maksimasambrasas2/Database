# Header Detection
# ================================
def find_header_row(df_raw, keywords=None):
    """Find the header row in Excel data."""
    if keywords is None:
        keywords = ['nominal', 'conventional', 'deviation', 'uncertainty',
                    'measurement', 'tolerance', 'oiml', 'serial', 'i.d', 'value']
    
    max_search = min(30, len(df_raw))
    best_row = None
    best_score = 0
    
    for idx in range(max_search):
        row = df_raw.iloc[idx]
        row_text = ' '.join([str(val).lower() for val in row.values if pd.notna(val)])
        
        keyword_count = sum(1 for kw in keywords if kw in row_text)
        non_null_count = row.notna().sum()
        score = keyword_count * 10 + non_null_count
        
        if score > best_score:
            best_score = score
            best_row = idx
    
    return best_row if best_row is not None else 0

# ================================
# Metadata Extraction
# ================================
def extract_metadata(file_path, lab_type):
    """Extract metadata from Admin/Input sheet."""
    try:
        xl = pd.ExcelFile(file_path)
        
        if lab_type == "F1/E2":
            sheet_name = 'Admin' if 'Admin' in xl.sheet_names else xl.sheet_names[0]
        else:
            sheet_name = 'Input' if 'Input' in xl.sheet_names else xl.sheet_names[0]
        
        df = pd.read_excel(file_path, sheet_name=sheet_name, header=None, dtype=str)
        
        metadata = {
            'file_name': os.path.basename(file_path),
            'lab_type': lab_type
        }
        
        patterns = {
            'certificate_number': r'certificate.*number',
            'calibration_date': r'date.*calibration|calibration.*date',
            'operator': r'^operator(?!.*second)',
            'second_operator': r'second.*operator',
            'instrument_type': r'instrument.*type|type.*instrument',
            'manufacturer': r'manufacturer',
            'model_number': r'model.*number|model',
            'serial_number': r'serial.*number',
            'client_id_number': r'client.*id|client.*number',
            'order_number': r'order.*number',
            'previous_certificate_number': r'previous.*certificate',
            'date_received': r'date.*received|received.*date',
            'calibration_procedure_number': r'procedure.*number|procedure',
            'calibration_standard': r'standard|reference',
            'number_of_weights': r'number.*weight',
            'range_of_weights': r'range.*weight',
            'method_used': r'method|description.*method',
            'comments': r'comment'
        }
        
        for idx, row in df.iterrows():
            values = [str(v).strip() for v in row.values if pd.notna(v) and str(v).strip()]
            
            if len(values) < 2:
                continue
            
            label = values[0].lower()
            value = values[1] if len(values) > 1 else ''
            
            for field, pattern in patterns.items():
                if re.search(pattern, label, re.IGNORECASE):
                    if field in ['calibration_date', 'date_received']:
                        metadata[field] = safe_date_convert(value)
                    else:
                        metadata[field] = value if value not in ['', 'nan', 'NaN'] else None
                    break
        
        return metadata
        
    except Exception as e:
        print(f"⚠️ Error extracting metadata: {e}")
        return {'file_name': os.path.basename(file_path), 'lab_type': lab_type}

