def find_header_row(df_raw, keywords=None):
    """Find the header row in Excel data."""
    if keywords is None:
        keywords = ['nominal', 'conventional', 'deviation', 'uncertainty',
                    'measurement', 'tolerance', 'oiml', 'serial', 'i.d', 'value']
    
    max_search = min(30, len(df_raw))
    best_row = None
    best_score = 0
    
    for idx in range(max_search):
        row = df_raw.iloc[idx]
        row_text = ' '.join([str(val).lower() for val in row.values if pd.notna(val)])
        
        keyword_count = sum(1 for kw in keywords if kw in row_text)
        non_null_count = row.notna().sum()
        score = keyword_count * 10 + non_null_count
        
        if score > best_score:
            best_score = score
            best_row = idx
    
    return best_row if best_row is not None else 0

# ================================
# Tolerance Lookup Function
# ================================
def get_tolerance_from_table(file_path, nominal_mass_kg, oiml_grade):
    """
    Get tolerance from Sheet2 tolerance table.
    For masses not in table, sum tolerances of component masses.
    Returns tolerance in mg.
    """
    try:
        # Read Sheet2
        df_tol = pd.read_excel(file_path, sheet_name='Sheet2', header=None)
        
        # Find the tolerance table (starts around row 3)
        # Header row has "Nominal" in column 10
        header_row = 3
        
        # Map OIML grade to column index
        oiml_column_map = {
            'E1': 11,
            'E2': 12,
            'F1': 13,
            'F2': 14,
            'M1': 15,
            'M1-2': 16,
            'M2': 17,
            'M3': 18
        }
        
        grade_upper = str(oiml_grade).upper().strip()
        if grade_upper not in oiml_column_map:
            print(f"   ⚠️ Unknown OIML grade: {oiml_grade}")
            return None
        
        tol_column = oiml_column_map[grade_upper]
        
        # Extract the tolerance table (column 10 has nominal, tol_column has tolerance)
        nominal_col = df_tol.iloc[4:, 10].dropna()  # Start from row 4
        tolerance_col = df_tol.iloc[4:, tol_column].dropna()
        
        # Build tolerance lookup dictionary
        tolerance_dict = {}
        for idx in range(min(len(nominal_col), len(tolerance_col))):
            nominal_str = str(nominal_col.iloc[idx]).strip()
            tolerance_val = tolerance_col.iloc[idx]
            
            # Parse nominal mass (e.g., "200kg", "100kg", "50kg")
            nominal_kg = extract_mass_from_string(nominal_str)
            if nominal_kg and pd.notna(tolerance_val):
                try:
                    tolerance_dict[nominal_kg] = float(tolerance_val)
                except:
                    pass
        
        print(f"   📊 Tolerance table loaded: {len(tolerance_dict)} entries")
        
        # Check if exact match exists
        if nominal_mass_kg in tolerance_dict:
            tolerance_mg = tolerance_dict[nominal_mass_kg]
            print(f"   ✓ Tolerance for {nominal_mass_kg}kg ({grade_upper}): {tolerance_mg}mg")
            return tolerance_mg
        
        # If not found, sum component masses
        # Standard masses in descending order
        standard_masses = [200, 100, 50, 20, 10, 5, 2, 1]
        
        remaining = nominal_mass_kg
        total_tolerance = 0
        components = []
        
        for mass in standard_masses:
            if mass in tolerance_dict:
                while remaining >= mass:
                    total_tolerance += tolerance_dict[mass]
                    components.append(f"{mass}kg")
                    remaining -= mass
        
        if remaining > 0.01:  # If we couldn't build it from standard masses
            print(f"   ⚠️ Could not find tolerance components for {nominal_mass_kg}kg")
            return None
        
        print(f"   ✓ Tolerance for {nominal_mass_kg}kg ({grade_upper}): {total_tolerance}mg (sum of {', '.join(components)})")
        return total_tolerance
        
    except Exception as e:
        print(f"   ❌ Error reading tolerance table: {e}")
        import traceback
        traceback.print_exc()
        return None

