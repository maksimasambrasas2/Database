# F1/E2 Extraction
# ================================
def extract_f1_e2_measurements(file_path, sheet_name):
    """Extract F1/E2 measurements from F1 Results or E2 Results sheet."""
    try:
        df_raw = pd.read_excel(file_path, sheet_name=sheet_name, header=None)
        header_row = find_header_row(df_raw)
        
        print(f"   📍 Header at row {header_row}")
        
        df = pd.read_excel(file_path, sheet_name=sheet_name, header=header_row)
        
        print(f"   📋 Original columns: {list(df.columns)[:15]}")
        
        original_cols = df.columns.tolist()
        df.columns = [normalize_column_name(col) for col in df.columns]
        col_map = dict(zip(df.columns, original_cols))
        
        # Remove empty rows
        df = df.dropna(how='all', axis=0)
        
        # Remove header repeat rows
        header_keywords = ['nominal', 'conventional', 'deviation', 'uncertainty', 'tolerance']
        for col in df.columns:
            if df[col].dtype == 'object':
                mask = df[col].astype(str).str.lower().apply(
                    lambda x: not any(kw in x for kw in header_keywords)
                )
                df = df[mask]
        
        df = df.reset_index(drop=True)
        
        result_df = pd.DataFrame()
        
        # Weight ID - look for "I.D. No." column
        weight_id_patterns = ['i_d_no', 'id_no', 'i_d']
        for col in df.columns:
            if any(pattern == col for pattern in weight_id_patterns):
                result_df['weight_id'] = df[col].astype(str).str.strip()
                print(f"   ✓ weight_id from: {col_map.get(col, col)}")
                break
        
        if 'weight_id' not in result_df.columns:
            print(f"   ⚠️ No weight_id column found!")
            return pd.DataFrame()
        
        # Filter to only rows with weight_id
        mask = (result_df['weight_id'].notna() & 
               (result_df['weight_id'] != '') & 
               (result_df['weight_id'] != 'nan') &
               (result_df['weight_id'].str.strip() != ''))
        result_df = result_df[mask]
        print(f"   🔍 {len(result_df)} rows with weight_id")
        
        if len(result_df) == 0:
            return pd.DataFrame()
        
        valid_indices = result_df.index
        
        # Nominal Value
        nominal_patterns = ['nominal', 'nominal_value']
        nominal_found = False
        for col in df.columns:
            if any(pattern in col for pattern in nominal_patterns) and col not in ['nominal1', 'nominal_1']:
                nominal_data = safe_numeric_convert(df.loc[valid_indices, col])
                if nominal_data.notna().sum() > 0:
                    result_df['nominal_value'] = nominal_data
                    print(f"   ✓ nominal_value from: {col_map.get(col, col)}")
                    nominal_found = True
                    break
        
        if not nominal_found:
            print(f"   ℹ️ Deriving nominal from conventional mass")
        
        # Conventional Mass
        conv_patterns = ['conventional', 'conventional_mass']
        for col in df.columns:
            if any(pattern in col for pattern in conv_patterns) and col not in ['conventional1', 'conventional_1']:
                result_df['conventional_mass'] = safe_numeric_convert(df.loc[valid_indices, col])
                print(f"   ✓ conventional_mass from: {col_map.get(col, col)}")
                break
        
        # Derive nominal if needed
        if 'nominal_value' not in result_df.columns or result_df['nominal_value'].isna().all():
            if 'conventional_mass' in result_df.columns:
                def round_to_nominal(val):
                    if pd.isna(val):
                        return None
                    standard_masses = [20000, 10000, 5000, 2000, 1000, 500, 200, 100, 50, 20, 10, 5, 2, 1]
                    return min(standard_masses, key=lambda x: abs(x - val))
                
                result_df['nominal_value'] = result_df['conventional_mass'].apply(round_to_nominal)
                print(f"   ✓ nominal_value derived")
        
        # Deviation
        dev_patterns = ['deviation', 'dev']
        for col in df.columns:
            if any(pattern in col for pattern in dev_patterns) and col not in ['deviation1', 'deviation_1']:
                result_df['deviation'] = safe_numeric_convert(df.loc[valid_indices, col])
                print(f"   ✓ deviation from: {col_map.get(col, col)}")
                break
        
        # Measurement Uncertainty
        unc_patterns = ['measurement', 'measurement_uncertainty', 'uncertainty']
        for col in df.columns:
            if any(pattern in col for pattern in unc_patterns) and col not in ['measurement1', 'measurement_1']:
                result_df['measurement_uncertainty'] = safe_numeric_convert(df.loc[valid_indices, col])
                print(f"   ✓ measurement_uncertainty from: {col_map.get(col, col)}")
                break
        
        # OIML Tolerance
        tol_patterns = ['oiml', 'tolerance']
        for col in df.columns:
            col_lower = col.lower()
            if any(pattern in col_lower for pattern in tol_patterns):
                tol_data = df[col].loc[valid_indices]
                tol_data = tol_data.astype(str).str.replace(r'[°&$]', '', regex=True).str.strip()
                tol_numeric = pd.to_numeric(tol_data, errors='coerce')
                
                if tol_numeric.notna().sum() > 0:
                    result_df['oiml_tolerance'] = tol_numeric
                    print(f"   ✓ oiml_tolerance from: {col_map.get(col, col)} ({tol_numeric.notna().sum()} values)")
                    break
        
        # Filter invalid IDs
        def is_valid_id(val):
            try:
                float_val = float(val)
                if '.' in val and len(val.split('.')[1]) > 2:
                    return False
            except:
                pass
            return True
        
        mask = result_df['weight_id'].apply(is_valid_id)
        result_df = result_df[mask]
        
        result_df = result_df.reset_index(drop=True)
        
        return result_df
        
    except Exception as e:
        print(f"   ❌ F1/E2 error: {e}")
        import traceback
        traceback.print_exc()
        return pd.DataFrame()

