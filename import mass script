def extract_measurements(file_path, lab_type):
    """Route to appropriate extraction function."""
    try:
        xl = pd.ExcelFile(file_path)
        
        sheet_name = None
        for s in xl.sheet_names:
            s_lower = s.lower()
            if lab_type == "F1/E2":
                if any(kw in s_lower for kw in ['f1 result', 'e2 result']):
                    sheet_name = s
                    break
            else:
                if any(kw in s_lower for kw in ['result', 'large', 'mass']):
                    sheet_name = s
                    break
        
        if sheet_name is None:
            print(f"   ⚠️ No results sheet")
            return pd.DataFrame()
        
        print(f"   📊 Sheet: '{sheet_name}'")
        
        if lab_type == "F1/E2":
            df = extract_f1_e2_measurements(file_path, sheet_name)
        else:
            df = extract_large_mass_measurements(file_path, sheet_name)
        
        print(f"   ✅ Extracted {len(df)} rows")
        if len(df) > 0:
            print(f"   📋 Columns: {list(df.columns)}")
        
        return df
        
    except Exception as e:
        print(f"   ❌ Extraction error: {e}")
        import traceback
        traceback.print_exc()
        return pd.DataFrame()

# ================================
# Database Insertion
# ================================
def insert_data(engine, file_path):
    """Extract and insert data."""
    print(f"\n{'='*60}")
    print(f"📄 {os.path.basename(file_path)}")
    print('='*60)
    
    lab_type = detect_lab_type(file_path)
    print(f"🔬 Lab: {lab_type}")
    
    if lab_type == "Unknown":
        print("⚠️ Unknown lab type")
        return False
    
    metadata = extract_metadata(file_path, lab_type)
    
    try:
        meta_df = pd.DataFrame([metadata])
        meta_df.to_sql('calibration_metadata', engine, if_exists='append', index=False)
        
        with engine.connect() as conn:
            result = conn.execute(text(
                "SELECT id FROM calibration_metadata WHERE file_name = :fn ORDER BY id DESC LIMIT 1"
            ), {"fn": metadata['file_name']})
            metadata_id = result.scalar()
        
        print(f"✅ Metadata (ID: {metadata_id})")
        
    except Exception as e:
        print(f"❌ Metadata error: {e}")
        return False
    
    df = extract_measurements(file_path, lab_type)
    
    if df.empty:
        print("⚠️ No measurement data")
        return False
    
    # Add metadata_id AND certificate_number
    df['metadata_id'] = metadata_id
    df['certificate_number'] = metadata.get('certificate_number', None)
    
    try:
        table = 'f1_e2_results' if lab_type == "F1/E2" else 'large_mass_results'
        df.to_sql(table, engine, if_exists='append', index=False)
        print(f"✅ Inserted {len(df)} rows into '{table}'")
        return True
        
    except Exception as e:
        print(f"❌ Insert error: {e}")
        import traceback
        traceback.print_exc()
        return False

# ================================
# Main Execution
# ================================
def run_import(folder_path='.', recreate_schema=True):
    """Main import function."""
    print("🚀 NML Calibration Data Import Tool")
    print("="*60)
    
    try:
        engine = create_engine(DB_URL)
        with engine.connect() as conn:
            conn.execute(text('SELECT 1'))
        print("✅ Database connected\n")
    except Exception as e:
        print(f"❌ Connection failed: {e}")
        return
    
    if recreate_schema:
        recreate_tables(engine)
    
    files = [f for f in os.listdir(folder_path) 
             if f.lower().endswith('.xlsm') and not f.startswith('~$')]
    
    if not files:
        print(f"⚠️ No .xlsm files in '{folder_path}'")
        return
    
    print(f"Found {len(files)} file(s)\n")
    
    success = 0
    for file in files:
        if insert_data(engine, os.path.join(folder_path, file)):
            success += 1
    
    print(f"\n{'='*60}")
    print("📊 SUMMARY")
    print('='*60)
    print(f"Processed: {len(files)}")
    print(f"Success: {success}")
    print(f"Failed: {len(files) - success}")
    
    try:
        with engine.connect() as conn:
            for table in ['calibration_metadata', 'f1_e2_results', 'large_mass_results']:
                count = conn.execute(text(f'SELECT COUNT(*) FROM {table}')).scalar()
                print(f"\n{table}: {count} records")
    except Exception as e:
        print(f"\n⚠️ Count error: {e}")
    
    print("\n✅ Import complete!")

