def extract_metadata(file_path, lab_type):
    """Extract metadata from Admin/Input sheet with proper field mapping."""
    try:
        xl = pd.ExcelFile(file_path)
        
        if lab_type == "F1/E2":
            sheet_name = 'Admin' if 'Admin' in xl.sheet_names else xl.sheet_names[0]
        else:
            sheet_name = 'Input' if 'Input' in xl.sheet_names else xl.sheet_names[0]
        
        df = pd.read_excel(file_path, sheet_name=sheet_name, header=None, dtype=str)
        
        metadata = {
            'file_name': os.path.basename(file_path),
            'lab_type': lab_type
        }
        
        # For F1/E2 files, use specific row mapping (Admin sheet has fixed structure)
        if lab_type == "F1/E2":
            # Fixed row positions in Admin sheet
            try:
                metadata['calibration_date'] = safe_date_convert(df.iloc[1, 1])  # Row 1, Col 1
                metadata['reference_weights'] = str(df.iloc[5, 1]).strip() if pd.notna(df.iloc[5, 1]) else None  # Row 5, Col 1 (Operator field)
                metadata['certificate_number'] = str(df.iloc[7, 1]).strip() if pd.notna(df.iloc[7, 1]) else None  # Row 7, Col 1
                metadata['manufacturer'] = str(df.iloc[10, 1]).strip() if pd.notna(df.iloc[10, 1]) else None  # Row 10, Col 1
                
                # Model Number determines if E2 or F1
                model_number = str(df.iloc[11, 1]).strip() if pd.notna(df.iloc[11, 1]) else None  # Row 11, Col 1
                metadata['job_type'] = model_number  # Store for later use
                
                metadata['instrument_type'] = str(df.iloc[12, 1]).strip() if pd.notna(df.iloc[12, 1]) else None  # Row 12, Col 1
                metadata['serial_number'] = str(df.iloc[13, 1]).strip() if pd.notna(df.iloc[13, 1]) else None  # Row 13, Col 1
                metadata['number_of_weights'] = str(df.iloc[15, 1]).strip() if pd.notna(df.iloc[15, 1]) else None  # Row 15, Col 1
                metadata['previous_certificate_number'] = str(df.iloc[16, 1]).strip() if pd.notna(df.iloc[16, 1]) else None  # Row 16, Col 1
                
                # Additional fields via pattern matching
                for idx, row in df.iterrows():
                    values = [str(v).strip() for v in row.values if pd.notna(v) and str(v).strip() not in ['', 'nan', 'NaN']]
                    if len(values) < 2:
                        continue
                    
                    label = values[0].lower().strip()
                    value = values[1]
                    
                    if 'date.*received|received.*date' in label:
                        metadata['date_received'] = safe_date_convert(value)
                    elif 'procedure.*number' in label:
                        metadata['calibration_procedure_number'] = value
                    elif 'standard' in label and 'reference' not in label:
                        metadata['calibration_standard'] = value
                    elif 'range.*weight' in label:
                        metadata['range_of_weights'] = value
                    elif 'method' in label or 'description.*method' in label:
                        metadata['method_used'] = value
                    elif 'comment' in label:
                        metadata['comments'] = value
                
            except Exception as e:
                print(f"   ⚠️ Error reading fixed Admin positions: {e}")
        
        else:  # Large Mass - use pattern matching
            patterns = {
                'certificate_number': r'(?:^|\s)cert(?:ificate)?\s*(?:no|number)',
                'calibration_date': r'(?:^|\s)date.*calibrat|calibrat.*date',
                'instrument_type': r'(?:^|\s)(?:instrument|unit)\s*(?:type|description)',
                'previous_certificate_number': r'previous.*cert',
                'date_received': r'date.*received|received.*date',
                'calibration_procedure_number': r'(?:calibration\s+)?procedure.*number|nml\s+procedure',
                'number_of_weights': r'number.*weight',
                'method_used': r'method|description.*method',
                'comments': r'^comment',
                'oiml_grade': r'oiml.*grade'
            }
            
            for idx, row in df.iterrows():
                values = [str(v).strip() for v in row.values if pd.notna(v) and str(v).strip() not in ['', 'nan', 'NaN']]
                
                if len(values) < 1:
                    continue
                
                label = values[0].lower().strip()
                value = values[1] if len(values) > 1 else None
                
                for field, pattern in patterns.items():
                    if re.search(pattern, label, re.IGNORECASE):
                        if field in ['calibration_date', 'date_received']:
                            metadata[field] = safe_date_convert(value)
                        elif value and value not in ['', 'nan', 'NaN', 'None']:
                            metadata[field] = value
                        break
        
        return metadata
        
    except Exception as e:
        print(f"⚠️ Error extracting metadata: {e}")
        import traceback
        traceback.print_exc()
        return {'file_name': os.path.basename(file_path), 'lab_type': lab_type}

