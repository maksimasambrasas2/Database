# Large Mass Extraction - CORRECTED
# ================================
def extract_large_mass_measurements(file_path, sheet_name='Input'):
    """Extract Large Mass measurements from Summary row in Input sheet + tolerance from Sheet2."""
    try:
        # Read Input sheet
        df_input = pd.read_excel(file_path, sheet_name='Input', header=None, dtype=str)
        
        print(f"   📊 Reading from Input sheet")
        
        # Find Summary row (usually row 32)
        summary_row = None
        for idx, row in df_input.iterrows():
            if 'summary' in str(row[3]).lower():
                summary_row = idx
                break
        
        if summary_row is None:
            print(f"   ⚠️ Summary row not found")
            return pd.DataFrame()
        
        print(f"   ✓ Found Summary row at index {summary_row}")
        
        # Extract from Summary row
        # Row structure: [nan, nan, nan, 'Summary', 'CR1704 / ', nominal, conventional, deviation, tolerance]
        row_data = df_input.iloc[summary_row]
        
        weight_id_raw = str(row_data[4]).strip()  # "CR1704 / "
        weight_id = weight_id_raw.replace('/', '').strip()
        
        nominal_str = str(row_data[5]).strip()  # Could be "200kg" or "350000"
        conventional_str = str(row_data[6]).strip()  # In grams
        deviation_str = str(row_data[7]).strip() if pd.notna(row_data[7]) else None
        
        # Parse values
        nominal_mass_kg = extract_mass_from_string(nominal_str)
        
        try:
            conventional_mass_g = float(conventional_str)
        except:
            print(f"   ⚠️ Could not parse conventional mass: {conventional_str}")
            return pd.DataFrame()
        
        # Calculate deviation if not directly provided
        if deviation_str and deviation_str not in ['nan', 'NaN', '']:
            try:
                deviation_g = float(deviation_str)
            except:
                # Calculate from conventional - nominal
                deviation_g = conventional_mass_g - (nominal_mass_kg * 1000)
        else:
            # Calculate from conventional - nominal
            deviation_g = conventional_mass_g - (nominal_mass_kg * 1000)
        
        deviation_mg = deviation_g * 1000
        
        print(f"   ✓ From Summary: weight_id={weight_id}, nominal={nominal_mass_kg}kg, conventional={conventional_mass_g}g, deviation={deviation_mg}mg")
        
        # Get OIML grade from earlier in Input sheet
        oiml_grade = None
        for idx, row in df_input.iterrows():
            if 'oiml grade' in str(row[0]).lower():
                oiml_grade = str(row[1]).strip()
                break
        
        if not oiml_grade:
            print(f"   ⚠️ OIML grade not found")
            return pd.DataFrame()
        
        print(f"   ✓ OIML Grade: {oiml_grade}")
        
        # Get tolerance from Sheet2 tolerance table
        tolerance_mg = get_tolerance_from_table(file_path, nominal_mass_kg, oiml_grade)
        
        if tolerance_mg is None:
            print(f"   ⚠️ Could not determine tolerance")
            # Continue anyway, just leave as None
        
        # Calculate uncertainty = tolerance / 5
        uncertainty_mg = tolerance_mg / 5 if tolerance_mg else None
        
        if uncertainty_mg:
            print(f"   ✓ Uncertainty: {uncertainty_mg}mg (tolerance / 5)")
        
        # Build result
        nominal_mass_g = nominal_mass_kg * 1000
        
        result_df = pd.DataFrame([{
            'weight_id': weight_id,
            'nominal_mass_g': nominal_mass_g,
            'conventional_mass_g': conventional_mass_g,
            'deviation_mg': deviation_mg,
            'measurement_uncertainty_mg': uncertainty_mg,
            'tolerance_mg': tolerance_mg
        }])
        
        print(f"   ✅ Extracted 1 row from Input + Sheet2")
        
        return result_df
        
    except Exception as e:
        print(f"   ❌ Large Mass error: {e}")
        import traceback
        traceback.print_exc()
        return pd.DataFrame()

