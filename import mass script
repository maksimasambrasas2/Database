def extract_large_mass_measurements(file_path, sheet_name):
    """Extract Large Mass measurements."""
    try:
        # Read with different header row approach
        df_raw = pd.read_excel(file_path, sheet_name=sheet_name, header=None)
        header_row = find_header_row(df_raw)
        
        print(f"   📍 Header at row {header_row}")
        
        # Read data starting AFTER unit row if it exists
        # Check if there's a unit row right after header
        if header_row + 1 < len(df_raw):
            next_row = df_raw.iloc[header_row + 1]
            next_row_str = ' '.join([str(v).lower() for v in next_row.values if pd.notna(v)])
            if any(unit in next_row_str for unit in ['kg', '±g', 'mg']):
                print(f"   🔧 Detected unit row at {header_row + 1}, skipping it")
                # Skip the unit row by starting from header_row + 2
                df = pd.read_excel(file_path, sheet_name=sheet_name, header=header_row, skiprows=[header_row + 1])
            else:
                df = pd.read_excel(file_path, sheet_name=sheet_name, header=header_row)
        else:
            df = pd.read_excel(file_path, sheet_name=sheet_name, header=header_row)
        
        print(f"   📋 All columns: {list(df.columns)}")
        
        original_cols = df.columns.tolist()
        df.columns = [normalize_column_name(col) for col in df.columns]
        col_map = dict(zip(df.columns, original_cols))
        
        # Remove empty rows
        df = df.dropna(how='all', axis=0)
        df = df.reset_index(drop=True)
        
        print(f"   🔍 Data rows: {len(df)}")
        
        if len(df) == 0:
            print(f"   ⚠️ No data rows")
            return pd.DataFrame()
        
        result_df = pd.DataFrame()
        
        # Weight ID - check first 2 unnamed columns
        weight_id_found = False
        unnamed_cols = [c for c in df.columns if 'unnamed' in c]
        
        for col in unnamed_cols[:2]:
            sample = df[col].dropna().head(10).astype(str)
            if len(sample) > 0:
                has_letters = any(bool(re.search(r'[a-zA-Z]', str(v))) for v in sample)
                if has_letters:
                    result_df['weight_id'] = df[col].astype(str).str.strip()
                    print(f"   ✓ weight_id from: {col_map.get(col, col)}")
                    weight_id_found = True
                    break
        
        # Nominal Mass (g) - "Value" column
        value_patterns = ['value', 'nominal']
        for col in df.columns:
            if any(pattern in col for pattern in value_patterns):
                result_df['nominal_mass_g'] = safe_numeric_convert(df[col])
                print(f"   ✓ nominal_mass_g from: {col_map.get(col, col)}")
                break
        
        # Conventional Mass (g) - "Before Adj" or "After Adj"
        conv_patterns = ['before_adj', 'after_adj', 'conventional']
        for col in df.columns:
            if any(pattern in col for pattern in conv_patterns):
                result_df['conventional_mass_g'] = safe_numeric_convert(df[col])
                print(f"   ✓ conventional_mass_g from: {col_map.get(col, col)}")
                break
        
        # Measurement Uncertainty (mg) - "Uncertainty"
        unc_patterns = ['uncertainty']
        for col in df.columns:
            if any(pattern in col for pattern in unc_patterns):
                result_df['measurement_uncertainty_mg'] = safe_numeric_convert(df[col])
                print(f"   ✓ measurement_uncertainty_mg from: {col_map.get(col, col)}")
                break
        
        # Tolerance (mg) - "Tolerance"
        tol_patterns = ['tolerance']
        for col in df.columns:
            if any(pattern in col for pattern in tol_patterns):
                result_df['tolerance_mg'] = safe_numeric_convert(df[col])
                print(f"   ✓ tolerance_mg from: {col_map.get(col, col)}")
                break
        
        # Filter: keep rows with at least nominal OR conventional mass
        filter_cols = [c for c in ['nominal_mass_g', 'conventional_mass_g'] if c in result_df.columns]
        if filter_cols:
            result_df = result_df.dropna(subset=filter_cols, how='all')
            print(f"   🔍 {len(result_df)} rows with mass data")
        
        if len(result_df) == 0:
            print(f"   ⚠️ No rows with mass data")
            return pd.DataFrame()
        
        result_df = result_df.reset_index(drop=True)
        result_df['row_number'] = range(1, len(result_df) + 1)
        
        return result_df
        
    except Exception as e:
        print(f"   ❌ Large Mass error: {e}")
        import traceback
        traceback.print_exc()
        return pd.DataFrame()

