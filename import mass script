# ------------------------
# Utilities
# ------------------------
def normalize_colname(s):
    """Sanitise a column name: lowercase, alnum+underscore, no leading digits."""
    if s is None:
        return "col"
    s = str(s)
    s = s.strip().lower()
    s = re.sub(r'\s+', '_', s)
    s = re.sub(r'[^0-9a-zA-Z_]', '', s)
    s = re.sub(r'_+', '_', s)
    s = s.strip('_')
    if re.match(r'^\d', s):
        s = 'c_' + s
    if s == "":
        s = "col"
    return s

def infer_sql_type(series):
    """Return a Postgres type guess for a pandas Series."""
    s = series.dropna()
    if s.empty:
        return 'text'
    # datetime detection
    if ptypes.is_datetime64_any_dtype(series):
        return 'timestamp'
    # numeric detection: if majority numeric, use double precision
    coerced = pd.to_numeric(series, errors='coerce')
    if coerced.count() >= max(1, int(0.5 * len(series))):  # at least 50% numeric
        return 'double precision'
    # fallback
    return 'text'

def ensure_table_exists(engine, table_name):
    """Create minimal table with id serial if it doesn't exist."""
    inspector = inspect(engine)
    if table_name in inspector.get_table_names():
        return
    with engine.begin() as conn:
        conn.execute(text(f'CREATE TABLE "{table_name}" (id SERIAL PRIMARY KEY)'))
    print(f"🛠 Created table {table_name} (minimal).")

def get_db_columns(engine, table_name):
    inspector = inspect(engine)
    if table_name not in inspector.get_table_names():
        return []
    cols = [c['name'] for c in inspector.get_columns(table_name)]
    return cols

def ensure_columns_exist(engine, table_name, columns_types):
    """Add missing columns to table. columns_types: {colname: sql_type}."""
    inspector = inspect(engine)
    existing = get_db_columns(engine, table_name)
    to_add = {c: columns_types[c] for c in columns_types if c not in existing}
    if not to_add:
        return []
    added = []
    with engine.begin() as conn:
        for col, coltype in to_add.items():
            # safe column name (we have already normalised it)
            sql = f'ALTER TABLE "{table_name}" ADD COLUMN "{col}" {coltype}'
            conn.execute(text(sql))
            added.append((col, coltype))
    if added:
        print(f"🛠 Added columns to {table_name}: {added}")
    return added

def insert_metadata_return_id(engine, metadata):
    """Ensure calibration_metadata exists, add missing columns, insert metadata and return id."""
    table = "calibration_metadata"
    ensure_table_exists(engine, table)
    # normalise metadata keys -> column names
    norm_meta = {normalize_colname(k): v for k, v in metadata.items() if k is not None}
    # infer types
    col_types = {k: ('timestamp' if isinstance(v, (pd.Timestamp, datetime)) else ('double precision' if isinstance(v, (int, float)) else 'text'))
                 for k,v in norm_meta.items()}
    ensure_columns_exist(engine, table, col_types)
    # Prepare and execute INSERT ... RETURNING id
    cols = list(norm_meta.keys())
    if not cols:
        # no metadata to insert - just select last id
        df = pd.read_sql(f"SELECT id FROM {table} ORDER BY id DESC LIMIT 1", con=engine)
        if df.empty:
            return None
        return int(df.iloc[0,0])
    col_list_sql = ', '.join(f'"{c}"' for c in cols)
    param_list_sql = ', '.join(f':{c}' for c in cols)
    params = {c: norm_meta[c] for c in cols}
    with engine.begin() as conn:
        sql = text(f'INSERT INTO "{table}" ({col_list_sql}) VALUES ({param_list_sql}) RETURNING id')
        res = conn.execute(sql, params)
        new_id = res.scalar()
    print(f"🔖 Inserted metadata (id={new_id}) columns: {cols}")
    return int(new_id)

